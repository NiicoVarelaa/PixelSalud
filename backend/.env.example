# ==========================
# CONFIGURACIÓN DE BASE DE DATOS
# ==========================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=pixel2025
DB_NAME=pixel_salud

# ==========================
# CONFIGURACIÓN DEL SERVIDOR
# ==========================
PORT=5000

# ==========================
# AUTENTICACIÓN JWT
# ==========================
# Genera una clave secreta segura para firmar tokens JWT
# Puedes usar: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SECRET_KEY=tu_clave_secreta_jwt_aqui

# ==========================
# MERCADO PAGO
# ==========================
# Token de acceso de Mercado Pago (obtener desde: https://www.mercadopago.com.ar/developers/panel)
MP_ACCESS_TOKEN=tu_access_token_de_mercadopago

# ==========================
# URLs DE LA APLICACIÓN
# ==========================
# URL del frontend (para redirecciones)
FRONTEND_URL=http://localhost:5173
# URL del backend (para webhooks)
BACKEND_URL=http://localhost:5000
# URL completa de OAuth en Google para login/registro social
GOOGLE_OAUTH_URL=
# Si prefieres construir la URL automáticamente en el backend, usa estas variables:
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Debe coincidir EXACTAMENTE con el callback configurado en Google Cloud
GOOGLE_REDIRECT_URI=http://localhost:5000/api/google-callback

# ==========================
# CONFIGURACIÓN DE EMAIL (SMTP)
# ==========================
# Servidor SMTP (por defecto Gmail)
SMTP_HOST=smtp.gmail.com
# Puerto SMTP (465 para SSL, 587 para TLS)
SMTP_PORT=465
# Email de la cuenta que enviará los correos
SMTP_USER=tu_email@gmail.com
# Contraseña de aplicación de Gmail (generar en: https://myaccount.google.com/apppasswords)
SMTP_PASS=
# Remitente que aparecerá en los emails
SMTP_FROM=PixelSalud <no-reply@pixelsalud.com>

# ==========================
# CUPÓN DE CUMPLEAÑOS (AUTOMÁTICO)
# ==========================
# Habilitar scheduler diario de cupones de cumpleaños
BIRTHDAY_COUPON_ENABLED=true
# Hora/minuto local de ejecución diaria (24h)
BIRTHDAY_COUPON_HOUR=9
BIRTHDAY_COUPON_MINUTE=0
# Ejecutar también al iniciar el backend (true/false)
BIRTHDAY_COUPON_RUN_ON_BOOT=false
# Configuración del cupón
BIRTHDAY_COUPON_PERCENT=20
BIRTHDAY_COUPON_MIN_AMOUNT=0
# ==========================
# CLOUDINARY (Almacenamiento de Imágenes)
# ==========================
# Servicio de hosting de imágenes en la nube (obtener credenciales en: https://cloudinary.com/console)
# Cloud Name de tu cuenta de Cloudinary
CLOUDINARY_CLOUD_NAME=tu_cloud_name
# API Key de Cloudinary
CLOUDINARY_API_KEY=tu_api_key
# API Secret de Cloudinary (mantener en secreto)
CLOUDINARY_API_SECRET=tu_api_secret